<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="com.duckduckgo.duckchat.impl.history.ChatHistoryEmptyStateView">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/emptyStateCenterGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.45" />

        <ImageView
            android:id="@+id/chatHistoryEmptyIllustration"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:importantForAccessibility="no"
            android:src="@drawable/duckai_chat_hero"
            app:layout_constraintBottom_toTopOf="@id/chatHistoryEmptyTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:id="@+id/chatHistoryEmptyTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/keyline_5"
            android:layout_marginTop="@dimen/keyline_4"
            android:gravity="center"
            android:text="@string/duck_ai_chat_history_empty_title"
            app:layout_constraintBottom_toTopOf="@id/chatHistoryEmptyPrimaryCta"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/chatHistoryEmptyIllustration"
            app:typography="h2" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/chatHistoryEmptyPrimaryCta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/keyline_5"
            android:layout_marginTop="@dimen/keyline_5"
            android:text="@string/duck_ai_chat_history_empty_cta_open"
            app:daxButtonSize="large"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/chatHistoryEmptyTitle" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>

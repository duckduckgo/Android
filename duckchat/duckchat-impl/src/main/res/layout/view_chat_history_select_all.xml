<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/chatHistorySelectAllRow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:minHeight="@dimen/oneLineItemHeight"
    android:paddingHorizontal="@dimen/keyline_4"
    android:paddingVertical="@dimen/keyline_2">

    <ImageView
        android:id="@+id/chatHistorySelectAllIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:importantForAccessibility="no"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@drawable/ic_chat_history_unchecked_24" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:id="@+id/chatHistorySelectAllLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/keyline_4"
        app:layout_constraintBottom_toBottomOf="@+id/chatHistorySelectAllIcon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/chatHistorySelectAllIcon"
        app:layout_constraintTop_toTopOf="@+id/chatHistorySelectAllIcon"
        app:typography="body1"
        tools:text="@string/duck_ai_chat_history_select_all" />

</androidx.constraintlayout.widget.ConstraintLayout>

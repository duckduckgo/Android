          "expectations": [
            {
              "type": "element",
              "selector": "#comprehensive-form",
              "failSilently": true
            }
          ],
          "actions": [
            {
              "actionType": "fillForm",
              "selector": "#comprehensive-form",
              "dataSource": "userProfile",
              "elements": [
                {
                  "type": "firstName",
                  "selector": "#fname"
                },
                {
                  "type": "middleName",

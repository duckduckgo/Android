          ],
          "id": "90deb9b3-42b1-4377-be87-f7da82c07f9d"
        },
        {
          "actionType": "extract",
          "selector": ".result-item",
          "noResultsSelector": "//h1[contains(., 'Sorry, we were unable to find any results')]",
          "profile": {
            "name": {
              "selector": "h2"
            },
            "age": {
              "selector": ".//p[contains(., 'Age')]",
              "afterText": "Age: "
            },
            "addressCityStateList": {
              "selector": ".//p[contains(., 'Location')]//following-sibling::ul[contains(@class, 'result-list')]//li",
              "findElements": true
            },
            "relativesList": {
              "selector": ".//p[contains(., 'Relatives')]//following-sibling::ul[contains(@class, 'result-list')]//li",
              "findElements": true
            },
            "profileUrl": {
              "identifierType": "hash"
            }
          },
          "id": "22b645d1-9504-4350-8031-0fa8268e4a2e"
        }
      ]

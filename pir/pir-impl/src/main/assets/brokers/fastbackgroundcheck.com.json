{
  "name": "FastBackgroundCheck.com",
  "url": "fastbackgroundcheck.com",
  "version": "0.6.0",
  "parent": "peoplefinders.com",
  "addedDatetime": 1706248800000,
  "optOutUrl": "https://www.fastbackgroundcheck.com/opt-out",
  "steps": [
    {
      "stepType": "scan",
      "scanType": "templatedUrl",
      "actions": [
        {
          "actionType": "navigate",
          "id": "58fdfa90-9b0c-4fda-8961-e73502f68474",
          "url": "https://www.fastbackgroundcheck.com/people/${firstName}-${lastName}/${city}-${state}"
        },
        {
          "actionType": "expectation",
          "_comment": "wait for cloudflare check to pass - we are using a negative xpath selector because CF challenge page has class 'page-manage-challenge' on the html element",
          "expectations": [
            {
              "type": "element",
              "selector": "//html[not(contains(@class, 'page-manage-challenge'))]",
              "failSilently": true
            }
          ],
          "id": "faa2a63e-1d47-45e9-a1f3-c1780b29cd1f"
        },
        {
          "actionType": "condition",
          "_comment": "Site sometimes redirects to /captcha with a reCAPTCHA after CF Turnstile passes. Not always present.",
          "expectations": [
            {
              "type": "element",
              "selector": ".g-recaptcha",
              "failSilently": true
            }
          ],
          "actions": [
            {
              "actionType": "getCaptchaInfo",
              "selector": ".g-recaptcha",
              "id": "61042b7b-f9df-4a52-a608-a9b9aff6ea48"
            },
            {
              "actionType": "solveCaptcha",
              "selector": ".g-recaptcha",
              "id": "cd974910-9705-4381-b273-584f2e300804"
            },
            {
              "actionType": "click",
              "elements": [
                {
                  "type": "button",
                  "selector": "//button[contains(text(), 'Submit')]"
                }
              ],
              "id": "d271d36b-9df8-4b8e-9c6d-42b343e8fb93"
            }
          ],
          "id": "7927f058-9aa9-477b-9671-b3ad06ca9100"
        },
        {
          "actionType": "extract",
          "id": "14dfda23-a4c3-483f-a67f-e89322636036",
          "selector": ".person-container",
          "noResultsSelector": "//h1[text()='Search Not Found']",
          "profile": {
            "name": {
              "selector": ".text-xl"
            },
            "age": {
              "selector": ".//span[starts-with(normalize-space(text()), 'Age ')]",
              "afterText": "Age "
            },
            "addressCityState": {
              "selector": ".//h2//a/span[@class='text-base']"
            },
            "addressCityStateList": {
              "selector": ".//div[h3[contains(text(), 'Past Addresses')]]",
              "afterText": ":",
              "separator": "•"
            },
            "relativesList": {
              "selector": ".//div[h3[contains(text(), 'Relatives')]]",
              "afterText": ":",
              "separator": ","
            },
            "profileUrl": {
              "selector": ".//a[contains(@title, 'public records for')]",
              "identifierType": "path",
              "identifier": "https://www.fastbackgroundcheck.com/people/${firstName}-${lastName}/id/${id}"
            }
          }
        }
      ]
    },
    {
      "stepType": "optOut",
      "optOutType": "parentSiteOptOut",
      "actions": []
    }
  ],
  "schedulingConfig": {
    "retryError": 48,
    "confirmOptOutScan": 72,
    "maintenanceScan": 120,
    "maxAttempts": -1
  },
  "removedAt": null
}

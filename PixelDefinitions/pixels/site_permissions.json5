{
    "m_site_permissions_prompt_shown": {
        "description": "Fired when a website permission prompt (camera, mic, location, DRM) is shown to the user.",
        "owners": ["jonathanKingston"],
        "triggers": ["other"],
        "suffixes": ["form_factor"],
        "parameters": [
            {
                "key": "type",
                "description": "The permission type requested by the website",
                "type": "string",
                "enum": ["camera", "microphone", "camera_and_microphone", "drm", "location"]
            },
            {
                "key": "partyContext",
                "description": "Relationship between the requesting origin and the top-level page: first_party (same hostname), same_site (same eTLD+1, different hostname), third_party (different eTLD+1), unknown (could not determine)",
                "type": "string",
                "enum": ["first_party", "same_site", "third_party", "unknown"]
            }
        ],
        "expires": "2026-09-30"
    }
}

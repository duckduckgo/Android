        "triggers": ["other"],
        "suffixes": ["form_factor"],
        "parameters": ["appVersion"]
    },
    "m_fire_tabs_promo_ntp_dismissed": {
        "description": "Fires when the user dismisses the NTP Fire Tabs promo card (Not Now or close)",
        "owners": ["0nko"],
        "triggers": ["other"],
        "suffixes": ["form_factor"],
        "parameters": ["appVersion"]
    },
    "m_fire_tabs_promo_tab_switcher_shown": {
        "description": "Fires when the Fire Tabs promo banner is shown in the tab switcher",
        "owners": ["0nko"],
        "triggers": ["other"],

{
    "autofill_harmony_preferences_retrieval_failed": {
        "description": "Retrieving autofill harmony preferences failed (daily unique)",
        "owners": ["CrisBarreiro"],
        "triggers": ["exception"],
        "suffixes": ["form_factor"],
        "parameters": [
            "appVersion",
            "error",
            {
                "key": "useHarmony",
                "description": "Whether the useHarmony feature flag is enabled",
                "type": "string",
                "enum": ["true", "false"]
            },
            {
                "key": "initialHarmonyValue",
                "description": "The value of useHarmony flag when harmony preferences were first initialized",
                "type": "string",
                "enum": ["true", "false", "null"]
            },
            {
                "key": "readFromHarmony",
                "description": "Whether the readFromHarmony feature flag is enabled",
                "type": "string",
                "enum": ["true", "false"]
            },
            {
                "key": "autofillService",
                "description": "Whether the autofill service feature flag is enabled (multi-process mode)",
                "type": "string",
                "enum": ["true", "false"]
            }
        ]
    },

<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/autofillDialogContentContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineStart"
            style="@style/AutofillDialogContentGuidelineStart" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineEnd"
            style="@style/AutofillDialogContentGuidelineEnd" />

        <!-- Success Icon -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/successIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/keyline_2"
            android:importantForAccessibility="no"
            android:scaleType="fitCenter"
            android:src="@drawable/bookmarks_import_128"
            app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            app:layout_constraintTop_toTopOf="parent" />

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:id="@+id/importResultTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/keyline_5"
            android:breakStrategy="balanced"
            android:gravity="center_horizontal"
            android:text="@string/importBookmarksSuccessTitle"
            app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            app:layout_constraintTop_toBottomOf="@id/successIcon"
            app:typography="h2" />

        <!-- Subtitle -->
        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:id="@+id/importResultSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/keyline_5"
            android:gravity="center"
            android:text="@string/importBookmarksSuccessSubtitle"
            android:textColor="?autofillDialogOnboardingExplanationColor"
            app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            app:layout_constraintTop_toBottomOf="@id/importResultTitle"
            app:textType="secondary"
            app:typography="body2" />

        <LinearLayout
            android:id="@+id/resultsContainer"
            android:layout_width="0dp"
            app:layout_constraintTop_toBottomOf="@id/importResultSubtitle"
            app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/autofill_rounded_border_import_background">

            <com.duckduckgo.common.ui.view.listitem.OneLineListItem
                android:id="@+id/bookmarksCountText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/keyline_5"
                android:layout_marginBottom="@dimen/keyline_2"
                app:leadingIcon="@drawable/ic_check_green_24"
                android:background="@drawable/autofill_rounded_container_listitem_background"
                tools:text="Bookmarks: 42" />

            <com.duckduckgo.common.ui.view.listitem.OneLineListItem
                android:id="@+id/bookmarksFailedText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/keyline_5"
                android:layout_marginBottom="@dimen/keyline_2"
                app:leadingIcon="@drawable/ic_cross_recolorable_red_24"
                android:background="@drawable/autofill_rounded_container_listitem_background"
                android:visibility="gone"
                tools:text="Failed: 3" />

        </LinearLayout>

        <!-- Done Button -->
        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/doneButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/importBookmarksSuccessDoneButton"
            app:daxButtonSize="large"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="1"
            app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            android:layout_marginBottom="@dimen/keyline_5"
            app:layout_constraintTop_toBottomOf="@id/resultsContainer" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>

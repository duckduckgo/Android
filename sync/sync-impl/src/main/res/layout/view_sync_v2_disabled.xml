<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/keyline_4"
        android:background="#f0f"
        tools:ignore="InvalidColorAttribute">

        <com.duckduckgo.common.ui.view.listitem.OneLineListItem
            android:id="@+id/syncThisDeviceToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:primaryText="@string/sync_settings_v2_this_device_cta_title"
            app:showSwitch="true" />
    </FrameLayout>

    <com.duckduckgo.common.ui.view.button.DaxButtonSecondary
        android:id="@+id/syncWithAnotherDeviceButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/keyline_5"
        android:layout_marginBottom="60dp"
        android:text="@string/sync_setup_with_another_device_cta_title"
        app:daxButtonSize="large"
        app:icon="@drawable/ic_qr_24" />

    <com.duckduckgo.common.ui.view.divider.HorizontalDivider
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/keyline_4" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/recoverDataItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:leadingIcon="@drawable/ic_sync_recovery_24"
        app:primaryText="@string/sync_setup_single_recover_data_cta_title" />

    <com.duckduckgo.common.ui.view.divider.HorizontalDivider
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/keyline_4" />

    <com.duckduckgo.sync.impl.ui.v2.SyncOnOtherPlatformsListItem
        android:id="@+id/synOnOtherPlatformsItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>

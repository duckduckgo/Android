<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbarAlwaysDrawVerticalTrack="true"
    android:fadeScrollbars="false"
    android:scrollbars="vertical">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <include
            android:id="@+id/includeToolbar"
            layout="@layout/include_default_toolbar" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/launchSyncSettingsButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="Launch Sync Settings" />

        <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:primaryText="@string/sync_internal_environment_header" />

        <com.duckduckgo.common.ui.view.listitem.TwoLineListItem
            android:id="@+id/sync_internal_environment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:showSwitch="true"
            app:primaryText="@string/sync_internal_environment_title"
            tools:secondaryText="@string/sync_internal_environment_subtitle_prod" />

        <com.duckduckgo.common.ui.view.divider.HorizontalDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:primaryText="Duck.ai Environment" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/openDuckAiDevScreenButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="Open Duck.ai Dev Screen" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/openDuckAiSetupUrlButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="Open Duck.ai Setup URL" />

        <com.duckduckgo.common.ui.view.divider.HorizontalDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:primaryText="V2 Connect Flow flags" />

        <com.duckduckgo.common.ui.view.listitem.OneLineListItem
            android:id="@+id/canUseV2ConnectFlowToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:showSwitch="true"
            app:primaryText="canUseV2ConnectFlow (master kill switch)" />

        <com.duckduckgo.common.ui.view.listitem.OneLineListItem
            android:id="@+id/canShowV2ConnectCodeToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:showSwitch="true"
            app:primaryText="canShowV2ConnectCode (display, requires canUseV2ConnectFlow)" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/openV2PairingDebugButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="V2 Pairing Debug" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/fetchAccessCredentialsButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="Fetch Access Credentials" />

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:id="@+id/accessCredentialsTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/keyline_4"
            android:layout_marginEnd="@dimen/keyline_4"
            app:typography="body2" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/requestScopedTokenButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="Request Scoped Token (ai_chats)" />

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:id="@+id/scopedTokenResultTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/keyline_4"
            android:layout_marginEnd="@dimen/keyline_4"
            android:ellipsize="end"
            android:maxLines="2"
            app:typography="body2" />

        <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:primaryText="Protected Keys" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/fetchKeysButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="Fetch Keys" />

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:id="@+id/keysTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/keyline_4"
            android:layout_marginEnd="@dimen/keyline_4"
            android:layout_marginBottom="@dimen/keyline_4"
            app:typography="body2" />

        <com.duckduckgo.common.ui.view.text.DaxTextInput
            android:id="@+id/createProtectedKeyPurposeInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/keyline_4"
            android:layout_marginEnd="@dimen/keyline_4"
            android:hint="Purpose (e.g. ai_chats, sync)"
            android:text="ai_chats"
            app:editable="true"
            app:type="single_line" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/createProtectedKeyButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="Create Protected Key" />

        <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:primaryText="3party Credential Management" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/createThirdPartyCredentialButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="Create 3party Credential" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/refreshThirdPartyCredentialButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="Refresh 3party Credential from Server" />

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:id="@+id/v2StoreFieldsTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/keyline_4"
            android:layout_marginEnd="@dimen/keyline_4"
            android:layout_marginTop="@dimen/keyline_4"
            android:layout_marginBottom="@dimen/keyline_4"
            app:typography="body2" />

        <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:primaryText="3party Recovery Code" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/showThirdPartyRecoveryQrButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="Show 3party Recovery QR" />

        <ImageView
            android:id="@+id/thirdPartyRecoveryQrImageView"
            android:layout_width="wrap_content"
            android:layout_margin="10dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            tools:ignore="ContentDescription" />

        <com.duckduckgo.common.ui.view.button.DaxButtonGhost
            android:id="@+id/copyThirdPartyRecoveryCodeButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="Copy 3party Recovery Code" />

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:id="@+id/thirdPartyRecoveryCodeTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/keyline_4"
            android:layout_marginEnd="@dimen/keyline_4"
            android:ellipsize="end"
            android:maxLines="3"
            app:typography="body2" />

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:id="@+id/thirdPartyRecoveryCodeDecodedTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/keyline_4"
            android:layout_marginEnd="@dimen/keyline_4"
            android:layout_marginTop="@dimen/keyline_2"
            android:ellipsize="end"
            android:maxLines="10"
            app:typography="body2" />

        <com.duckduckgo.common.ui.view.divider.HorizontalDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <com.duckduckgo.common.ui.view.text.DaxTextInput
            android:id="@+id/sync_recovery_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/keyline_4"
            android:hint="@string/sync_internal_recovery_code"
            app:editable="true"
            app:type="single_line" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/sync_recovery_code_cta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:daxButtonSize="large"
            android:text="@string/sync_internal_recovery_code_cta"/>

        <com.duckduckgo.common.ui.view.divider.HorizontalDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:id="@+id/blockStoreSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:primaryText="@string/sync_internal_block_store_header" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/blockStoreApiInUse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                app:typography="body1" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/blockStoreFeatureFlag"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                app:typography="body1" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/blockStoreAvailability"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                app:typography="body1" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/blockStoreDeviceLockStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                app:typography="body1" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/blockStoreE2eStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                app:typography="body1" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/blockStoreInferredBackupStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                app:typography="body1" />

            <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:primaryText="@string/sync_internal_block_store_current_value_label" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/blockStoreCurrentValue"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:typography="body1" />

            <com.duckduckgo.common.ui.view.text.DaxTextInput
                android:id="@+id/blockStoreRecoveryCodeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/keyline_4"
                android:hint="@string/sync_internal_block_store_recovery_code_hint"
                app:editable="true"
                app:type="single_line" />

            <com.duckduckgo.common.ui.view.text.DaxTextInput
                android:id="@+id/blockStoreDeviceIdInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                android:layout_marginBottom="@dimen/keyline_4"
                android:hint="@string/sync_internal_block_store_device_id_hint"
                app:editable="true"
                app:type="single_line" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:orientation="horizontal">

                <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
                    android:id="@+id/blockStoreWriteButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:text="@string/sync_internal_block_store_write" />

                <com.duckduckgo.common.ui.view.button.DaxButtonGhost
                    android:id="@+id/blockStoreClearButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:text="@string/sync_internal_block_store_clear" />

            </LinearLayout>

            <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
                android:id="@+id/blockStoreWriteRecoveryCodeButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="4dp"
                app:daxButtonSize="large"
                android:text="@string/sync_internal_block_store_write_recovery_code" />

            <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
                android:id="@+id/launchRecoverDataScreenButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="4dp"
                app:daxButtonSize="large"
                android:text="@string/sync_internal_launch_recover_data_screen"/>

        </LinearLayout>

        <com.duckduckgo.common.ui.view.divider.HorizontalDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:primaryText="@string/sync_internal_device_header" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/sync_favicons_prompt_cta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:daxButtonSize="large"
            android:text="@string/sync_internal_favicons_prompt_cta"/>

        <com.duckduckgo.common.ui.view.divider.HorizontalDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:primaryText="@string/sync_internal_account_header" />

        <LinearLayout
            android:id="@+id/uuidsViewGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
                android:id="@+id/userIdSectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:primaryText="@string/userIdSectionHeader" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/userIdTextView"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:typography="body1" />

            <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
                android:id="@+id/deviceIdSectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:primaryText="@string/deviceIdSectionHeader" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/deviceIdTextView"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:typography="body1" />

            <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
                android:id="@+id/deviceNameSectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:primaryText="@string/deviceNameSectionHeader" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/deviceNameTextView"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:typography="body1" />

            <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
                android:id="@+id/primaryKeySectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:primaryText="Primary key" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/primaryKeyTextView"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:typography="body1" />

            <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
                android:id="@+id/secretKeySectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:primaryText="Secret key" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/secretKeyTextView"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:typography="body1" />

            <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
                android:id="@+id/tokenSectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:primaryText="Latest token" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/tokenTextView"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                android:ellipsize="end"
                android:maxLines="3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:typography="body1" />

            <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:primaryText="Recovery Code" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/recoveryCodeTextView"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                app:typography="body1" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/recoveryCodeDecodedTextView"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                android:layout_marginTop="@dimen/keyline_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="5"
                app:typography="body2" />

            <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
                android:id="@+id/connectedDevicesSectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:primaryText="Connected Devices" />

            <LinearLayout
                android:id="@+id/connectedDevicesList"
                android:layout_width="wrap_content"
                android:layout_margin="10dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
                android:id="@+id/createAccountButton"
                android:layout_width="wrap_content"
                android:layout_margin="10dp"
                android:layout_height="wrap_content"
                android:text="Create account" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/accountStateTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/keyline_4"
                android:layout_marginEnd="@dimen/keyline_4"
                android:text="Signed in"
                android:layout_gravity="center"
                app:typography="body1" />
        </LinearLayout>

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/readQRButton"
            android:layout_width="wrap_content"
            android:layout_margin="10dp"
            android:layout_height="wrap_content"
            android:text="Read QR code" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/showQRCode"
            android:layout_width="wrap_content"
            android:layout_margin="10dp"
            android:layout_height="wrap_content"
            android:text="Show QR code" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/readConnectQRCode"
            android:layout_width="wrap_content"
            android:layout_margin="10dp"
            android:layout_height="wrap_content"
            android:text="Connect (read QR)" />

        <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
            android:id="@+id/connectQRCode"
            android:layout_width="wrap_content"
            android:layout_margin="10dp"
            android:layout_height="wrap_content"
            android:text="Connect (show QR)" />

        <ImageView
            android:id="@+id/qrCodeImageView"
            android:layout_width="wrap_content"
            android:layout_margin="10dp"
            android:layout_height="wrap_content"

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:paddingHorizontal="12dp">

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:id="@+id/addressBarTitleHidden"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/preOnboardingAddressBarTitle"
            android:visibility="invisible"
            app:typography="onboarding_title" />

        <com.duckduckgo.common.ui.view.TypeAnimationTextView
            android:id="@+id/addressBarTitle"
            style="@style/Typography.DuckDuckGo.Onboarding.Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:textColor="?attr/daxColorPrimaryText" />

    </FrameLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/addressBarPositionContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/keyline_4"
        android:layout_marginBottom="@dimen/keyline_2"
        android:alpha="0"
        tools:alpha="1">

        <LinearLayout
            android:id="@+id/topOmnibarContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/keyline_2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/spacerTopBottom"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="160dp">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:foreground="@drawable/selectable_rounded_ripple">

                <ImageView
                    android:id="@+id/topOmnibarToggleImageBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:importantForAccessibility="no"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/topOmnibarToggleImage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/preOnboardingAddressBarPositionTop"
                    android:scaleType="fitCenter"
                    tools:src="@drawable/mobile_toolbar_top_selected_light" />

            </FrameLayout>

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="@string/preOnboardingAddressBarPositionTop"
                android:textAppearance="@style/Typography.DuckDuckGo.Onboarding.Label" />

            <com.duckduckgo.common.ui.view.button.RadioButton
                android:id="@+id/topOmnibarToggleCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@null"
                android:clickable="false"
                android:focusable="false"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                app:buttonTint="@color/onboarding_radio_button_tint"
                tools:ignore="DeprecatedWidgetInXml,InvalidColorAttribute" />

        </LinearLayout>

        <Space
            android:id="@+id/spacerTopBottom"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintEnd_toStartOf="@+id/bottomOmnibarContainer"
            app:layout_constraintStart_toEndOf="@+id/topOmnibarContainer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="56dp" />

        <LinearLayout
            android:id="@+id/bottomOmnibarContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/keyline_2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/spacerBottomSplit"
            app:layout_constraintStart_toEndOf="@+id/spacerTopBottom"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="160dp">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:foreground="@drawable/selectable_rounded_ripple">

                <ImageView
                    android:id="@+id/bottomOmnibarToggleImageBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:importantForAccessibility="no"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/bottomOmnibarToggleImage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/preOnboardingAddressBarPositionBottom"
                    android:scaleType="fitCenter"
                    tools:src="@drawable/mobile_toolbar_bottom_unselected_light" />

            </FrameLayout>

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="@string/preOnboardingAddressBarPositionBottom"
                android:textAppearance="@style/Typography.DuckDuckGo.Onboarding.Label" />

            <com.duckduckgo.common.ui.view.button.RadioButton
                android:id="@+id/bottomOmnibarToggleCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@null"
                android:clickable="false"
                android:focusable="false"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                app:buttonTint="@color/onboarding_radio_button_tint"
                tools:ignore="DeprecatedWidgetInXml,InvalidColorAttribute" />

        </LinearLayout>

        <Space
            android:id="@+id/spacerBottomSplit"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintEnd_toStartOf="@+id/splitOmnibarContainer"
            app:layout_constraintStart_toEndOf="@+id/bottomOmnibarContainer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="56dp" />

        <LinearLayout
            android:id="@+id/splitOmnibarContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/keyline_2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/spacerBottomSplit"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="160dp">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:foreground="@drawable/selectable_rounded_ripple">

                <ImageView
                    android:id="@+id/splitOmnibarToggleImageBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:importantForAccessibility="no"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/splitOmnibarToggleImage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/preOnboardingAddressBarPositionSplit"
                    android:scaleType="fitCenter"
                    tools:src="@drawable/mobile_toolbar_split_unselected_light" />

            </FrameLayout>

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="@string/preOnboardingAddressBarPositionSplit"
                android:textAppearance="@style/Typography.DuckDuckGo.Onboarding.Label" />

            <com.duckduckgo.common.ui.view.button.RadioButton
                android:id="@+id/splitOmnibarToggleCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@null"
                android:clickable="false"
                android:focusable="false"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                app:buttonTint="@color/onboarding_radio_button_tint"
                tools:ignore="DeprecatedWidgetInXml,InvalidColorAttribute" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>

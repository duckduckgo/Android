<resources xmlns:tools="http://schemas.android.com/tools">

    <attr name="onboardingTextPrimary" format="color" />
    <attr name="onboardingTextSecondary" format="color" />
    <attr name="onboardingSurfaceBackdrop" format="color" />
    <attr name="onboardingSurfaceTertiary" format="color" />
    <attr name="onboardingSurfaceDecorationPrimary" format="color" />
    <attr name="onboardingSurfaceDecorationTertiary" format="color" />
    <attr name="onboardingAccentAltPrimary" format="color" />
    <attr name="onboardingAccentAltGlowPrimary" format="color" />
    <attr name="onboardingAccentAltGlowSecondary" format="color" />
    <attr name="onboardingAccentBrand" format="color" />
    <attr name="onboardingAccentContentPrimary" format="color" />
    <attr name="onboardingAccentPrimary" format="color" />
    <attr name="onboardingAccentSecondary" format="color" />
    <attr name="onboardingAccentGlowPrimary" format="color" />
    <attr name="onboardingIconsSecondary" format="color" />
    <attr name="onboardingIconsTertiary" format="color" />
    <attr name="onboardingControlFillTertiary" format="color" />
    <color name="onboardingBubbleShadowColor">#08000000</color>

    <style name="Theme.DuckDuckGo.Light.Onboarding" parent="Theme.DuckDuckGo.Light">

        <!--Onboarding Colors-->
        <item name="onboardingTextPrimary">#F5242323</item> <!--96%-->
        <item name="onboardingTextSecondary">#99000000</item> <!--60%-->
        <item name="onboardingSurfaceBackdrop">@color/white</item>
        <item name="onboardingSurfaceTertiary">@color/white</item>
        <item name="onboardingSurfaceDecorationPrimary">#17242323</item> <!--9% Alpha-->
        <item name="onboardingSurfaceDecorationTertiary">#3D242323</item> <!--24% Alpha-->
        <item name="onboardingAccentAltPrimary">@color/pondwater20</item>
        <item name="onboardingAccentAltGlowPrimary">#29A1CFF7</item> <!--16% Alpha-->
        <item name="onboardingAccentAltGlowSecondary">#14A1CFF7</item> <!--8% Alpha-->
        <item name="onboardingAccentBrand">@color/mandarin50</item>
        <item name="onboardingAccentContentPrimary">@color/white</item>
        <item name="onboardingAccentPrimary">@color/pondwater50</item>
        <item name="onboardingAccentSecondary">@color/mandarin60</item>
        <item name="onboardingAccentGlowPrimary">#332F95EE</item> <!--20% Alpha-->
        <item name="onboardingControlFillTertiary">@color/black12</item>
        <item name="onboardingIconsSecondary">#99383838</item> <!--60% Alpha-->
        <item name="onboardingIconsTertiary">#66242323</item> <!--40% Alpha-->

        <!--Surface-->
        <item name="daxColorBackground">?attr/onboardingSurfaceBackdrop</item>
        <item name="daxColorContainer">?attr/onboardingSurfaceDecorationPrimary</item>

        <!--Accent-->
        <item name="daxColorAccentBlue">?attr/onboardingAccentPrimary</item>

        <!--Text-->
        <item name="textAppearanceH2">@style/Typography.DuckDuckGo.Onboarding.Title</item>
        <item name="textAppearanceButton">@style/Typography.DuckDuckGo.Onboarding.Button</item>
        <item name="daxColorSecondaryText">?attr/onboardingTextSecondary</item>

        <!--Button-->
        <item name="daxButtonPrimary">
            @style/Widget.DuckDuckGo.DaxButton.TextButton.Onboarding.Primary
        </item>
        <item name="daxButtonSecondary">
            @style/Widget.DuckDuckGo.DaxButton.TextButton.Onboarding.Secondary
        </item>

        <item name="daxColorButtonPrimaryContainer">?attr/onboardingAccentBrand</item>
        <item name="daxColorButtonPrimaryContainerPressed">?attr/onboardingAccentSecondary</item>

        <item name="daxColorButtonSecondaryContainer">@color/black6</item>
        <item name="daxColorButtonSecondaryContainerPressed">@color/black12</item>

        <item name="daxColorButtonPrimaryText">?attr/onboardingAccentContentPrimary</item>
        <item name="daxColorButtonPrimaryTextPressed">?attr/onboardingAccentContentPrimary</item>
        <item name="daxColorButtonSecondaryText">?attr/onboardingTextPrimary</item>
        <item name="daxColorButtonSecondaryTextPressed">?attr/onboardingTextPrimary</item>

        <!-- Text -->
        <item name="daxColorPrimaryText">?attr/onboardingTextPrimary</item>
    </style>

    <style name="Theme.DuckDuckGo.Dark.Onboarding" parent="Theme.DuckDuckGo.Dark">

        <!--Onboarding Colors-->
        <item name="onboardingTextPrimary">@color/white</item>
        <item name="onboardingTextSecondary">#99FFFFFF</item> <!--60%-->
        <item name="onboardingSurfaceBackdrop">#133E7C</item>
        <item name="onboardingSurfaceTertiary">#011D34</item>
        <item name="onboardingSurfaceDecorationPrimary">#0FFFFFFF</item> <!--6% Alpha-->
        <item name="onboardingSurfaceDecorationTertiary">@color/white20</item>
        <item name="onboardingAccentAltPrimary">#133E7C</item>
        <item name="onboardingAccentAltGlowPrimary">#1FA1CFF7</item> <!--12% Alpha-->
        <item name="onboardingAccentAltGlowSecondary">#14A1CFF7</item> <!--8% Alpha-->
        <item name="onboardingAccentBrand">@color/pollen30</item>
        <item name="onboardingAccentContentPrimary">@color/pollen100</item>
        <item name="onboardingAccentPrimary">@color/pondwater40</item>
        <item name="onboardingAccentSecondary">@color/pollen40</item>
        <item name="onboardingAccentGlowPrimary">#2975B6EB</item> <!--16% Alpha-->
        <item name="onboardingControlFillTertiary">@color/white24</item>
        <item name="onboardingIconsSecondary">#7AFBFAF9</item> <!--48% Alpha-->
        <item name="onboardingIconsTertiary">#7AFBFAF9</item> <!--48% Alpha-->

        <!--Surface-->
        <item name="daxColorBackground">?attr/onboardingSurfaceBackdrop</item>
        <item name="daxColorContainer">?attr/onboardingSurfaceDecorationPrimary</item>

        <!--Accent-->
        <item name="daxColorAccentBlue">?attr/onboardingAccentPrimary</item>

        <!--Text-->
        <item name="textAppearanceH2">@style/Typography.DuckDuckGo.Onboarding.Title</item>
        <item name="textAppearanceButton">@style/Typography.DuckDuckGo.Onboarding.Button</item>
        <item name="daxColorSecondaryText">?attr/onboardingTextSecondary</item>


        <!--Button-->
        <item name="daxButtonPrimary">
            @style/Widget.DuckDuckGo.DaxButton.TextButton.Onboarding.Primary
        </item>
        <item name="daxButtonSecondary">
            @style/Widget.DuckDuckGo.DaxButton.TextButton.Onboarding.Secondary
        </item>

        <item name="daxColorButtonPrimaryContainer">?attr/onboardingAccentBrand</item>
        <item name="daxColorButtonPrimaryContainerPressed">?attr/onboardingAccentSecondary</item>

        <item name="daxColorButtonSecondaryContainer">@color/white12</item>
        <item name="daxColorButtonSecondaryContainerPressed">@color/white24</item>

        <item name="daxColorButtonPrimaryText">?attr/onboardingAccentContentPrimary</item>
        <item name="daxColorButtonPrimaryTextPressed">?attr/onboardingAccentContentPrimary</item>
        <item name="daxColorButtonSecondaryText">?attr/onboardingTextPrimary</item>
        <item name="daxColorButtonSecondaryTextPressed">?attr/onboardingTextPrimary</item>

        <!-- Text -->
        <item name="daxColorPrimaryText">?attr/onboardingTextPrimary</item>
    </style>

    <style name="Typography.DuckDuckGo.Onboarding" />

    <style name="Typography.DuckDuckGo.Onboarding.WelcomeTitle">
        <item name="android:textSize">44sp</item>
        <item name="android:textColor">?attr/onboardingTextPrimary</item>
        <item name="android:lineSpacingExtra">-10sp</item>
        <item name="android:fontFamily">@font/ducksansdisplay_medium</item>
    </style>

    <style name="Typography.DuckDuckGo.Onboarding.Title">
        <item name="android:textSize">24sp</item>
        <item name="android:lineSpacingExtra">-1sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/ducksansdisplay_bold</item>
    </style>

    <style name="Typography.DuckDuckGo.Onboarding.Body">
        <item name="android:textSize">18sp</item>
        <item name="android:lineSpacingExtra">0sp</item>
        <item name="android:fontFamily">@font/ducksansproduct_regular</item>
    </style>

    <style name="Typography.DuckDuckGo.Onboarding.ChartComparison">
        <item name="android:textSize">14sp</item>
        <item name="typography">body1</item>
        <item name="android:lineSpacingExtra">-1sp</item>
        <item name="android:fontFamily">@font/ducksansproduct_regular</item>
    </style>

    <style name="Typography.DuckDuckGo.Onboarding.Button">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:fontFamily">@font/ducksansproduct_regular</item>
    </style>

    <style name="Typography.DuckDuckGo.Onboarding.Label">
        <item name="android:textSize">12sp</item>
        <item name="android:lineSpacingExtra">-3sp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:fontFamily">@font/ducksansdisplay_regular</item>
    </style>

    <style name="Widget.DuckDuckGo.DaxButton.TextButton.Onboarding" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textAppearance">?attr/textAppearanceButton</item>
        <item name="cornerRadius">64dp</item>
        <item name="android:insetTop">4dp</item>
        <item name="android:insetBottom">4dp</item>
    </style>

    <style name="Widget.DuckDuckGo.DaxButton.TextButton.Onboarding.Primary">
        <item name="android:textColor">?attr/daxColorButtonPrimaryText</item>
        <item name="backgroundTint">?attr/daxColorButtonPrimaryContainer</item>
        <item name="rippleColor">?attr/daxColorButtonPrimaryContainerPressed</item>
        <item name="iconTint">?attr/daxColorButtonPrimaryText</item>
    </style>

    <style name="Widget.DuckDuckGo.DaxButton.TextButton.Onboarding.Secondary">
        <item name="android:textColor">?attr/daxColorButtonSecondaryText</item>
        <item name="backgroundTint">?attr/daxColorButtonSecondaryContainer</item>
        <item name="rippleColor">?attr/daxColorButtonSecondaryContainerPressed</item>
        <item name="iconTint">?attr/daxColorButtonSecondaryText</item>
        <item name="android:textAppearance">@style/Typography.DuckDuckGo.Onboarding.Button</item>
        <item name="strokeColor">?attr/daxColorButtonSecondaryContainer</item>
    </style>

</resources>
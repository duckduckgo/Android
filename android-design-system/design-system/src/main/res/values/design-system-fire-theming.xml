<resources>

    <style name="Theme.DuckDuckGo.Light.Fire" parent="Theme.DuckDuckGo.Light">
        <item name="daxColorTabHighlight">?attr/daxColorFireModeAccentLight</item>

        <item name="daxColorOmnibarAccent">?attr/daxColorFireModeAccentLight</item>
        <item name="daxOmnibarTextColorHighlight">?attr/daxColorFireModeAccentLightTranslucent</item>
        <item name="daxColorAccentAltPrimary">?attr/daxColorOmnibarAccent</item>
        <item name="daxColorAccentAltContentPrimary">?attr/daxColorWhite</item>

        <item name="colorControlActivated">?attr/daxColorFireModeAccentLight</item>
        <item name="daxColorSnackbarAction">?attr/daxColorFireModeAccentLight</item>

        <item name="daxColorInputModeIndicatorShadow">?attr/daxColorBlack</item>

        <item name="daxIconTabSwitcher">@drawable/ic_tab_fire_mode_24</item>
        <item name="daxDrawableTabPlaceholderPreview">@drawable/ic_fire_tab_placeholder_96</item>

        <item name="daxInputModeCardThemeOverlay">@style/ThemeOverlay.DuckDuckGo.InputModeCard.DarkFire</item>
        <item name="daxOmnibarThemeOverlay">@style/ThemeOverlay.DuckDuckGo.Omnibar.FireLight</item>
    </style>

    <style name="Theme.DuckDuckGo.Dark.Fire" parent="Theme.DuckDuckGo.Dark">
        <item name="daxColorTabHighlight">?attr/daxColorFireModeAccentDark</item>

        <item name="daxColorOmnibarAccent">?attr/daxColorFireModeAccentDark</item>
        <item name="daxOmnibarTextColorHighlight">?attr/daxColorFireModeAccentDarkTranslucent</item>
        <item name="daxColorAccentAltPrimary">?attr/daxColorOmnibarAccent</item>

        <item name="daxColorAccentAltContentPrimary">?attr/daxColorBlack</item>
        <item name="daxColorOmnibarAccentContent">?attr/daxColorBlack</item>

        <item name="colorControlActivated">?attr/daxColorFireModeAccentDark</item>
        <item name="daxColorSnackbarAction">?attr/daxColorFireModeAccentDark</item>

        <item name="daxIconTabSwitcher">@drawable/ic_tab_fire_mode_24</item>
        <item name="daxDrawableTabPlaceholderPreview">@drawable/ic_fire_tab_placeholder_96</item>

        <item name="daxOmnibarThemeOverlay">@style/ThemeOverlay.DuckDuckGo.Omnibar.FireDark</item>
    </style>

    <style name="ThemeOverlay.DuckDuckGo.Omnibar.None" parent="" />

    <style name="ThemeOverlay.DuckDuckGo.Omnibar.FireLight" parent="Theme.DuckDuckGo.Dark">
        <!-- The omnibar island is dark (#3D3D3D) even in light Fire mode, so its accent uses the
             dark fire accent (mandarin40) — orange on a dark background per the Fire Mode spec. -->
        <item name="daxColorWindow">@color/omnibar_card_fire_light</item>
        <item name="daxColorOmnibarAccent">?attr/daxColorFireModeAccentDark</item>
        <item name="daxOmnibarTextColorHighlight">?attr/daxColorFireModeAccentDarkTranslucent</item>
        <item name="colorControlActivated">?attr/daxColorFireModeAccentDark</item>
    </style>

    <style name="ThemeOverlay.DuckDuckGo.Omnibar.FireDark" parent="Theme.DuckDuckGo.Dark">
        <item name="daxColorWindow">@color/omnibar_card_fire_dark</item>
        <item name="daxColorOmnibarAccent">?attr/daxColorFireModeAccentDark</item>
        <item name="daxOmnibarTextColorHighlight">?attr/daxColorFireModeAccentDarkTranslucent</item>
        <item name="colorControlActivated">?attr/daxColorFireModeAccentDark</item>
    </style>

    <!-- Applied to the input mode widget card via android:theme. The DarkFire variant re-applies the
         full dark Fire theme to the card subtree so it is pixel-identical to dark Fire mode; None is a
         no-op used by every theme that should leave the card on its own palette. -->
    <style name="ThemeOverlay.DuckDuckGo.InputModeCard.None" parent="" />

    <style name="ThemeOverlay.DuckDuckGo.InputModeCard.DarkFire" parent="Theme.DuckDuckGo.Dark.Fire">
        <!-- The card is dark even in light Fire mode, so it mirrors dark Fire mode exactly: the
             dark fire accent (mandarin40) with black content on top of it. -->
        <item name="daxColorOmnibarAccent">?attr/daxColorFireModeAccentDark</item>
        <item name="daxOmnibarTextColorHighlight">?attr/daxColorFireModeAccentDarkTranslucent</item>
        <item name="daxColorAccentAltPrimary">?attr/daxColorOmnibarAccent</item>
        <item name="daxColorAccentAltContentPrimary">?attr/daxColorBlack</item>
        <item name="daxColorOmnibarAccentContent">?attr/daxColorBlack</item>
        <item name="colorControlActivated">?attr/daxColorFireModeAccentDark</item>
    </style>

</resources>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:paddingTop="@dimen/keyline_5">

    <com.duckduckgo.common.ui.view.listitem.SectionHeaderListItem
        android:id="@+id/oneLineListTitle"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        app:primaryText="Single Line Items" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionView"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:primaryText="This is a simple item " />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeOneLineSimple"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionNoCompose"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemWithSmallImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:leadingIconSize="small"
        app:leadingIcon="@drawable/ic_dax_icon"
        app:primaryText="Item with Small Leading Image " />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionNoCompose"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemWithSmallImageAndBg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:leadingIconSize="small"
        app:leadingIconBackground="circular"
        app:leadingIcon="@drawable/ic_dax_icon"
        app:primaryText="Item with Small Leading Image " />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionView"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemWithMediumImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:leadingIconSize="medium"
        app:leadingIcon="@drawable/ic_dax_icon"
        app:primaryText="Item with Medium Leading Image " />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeOneLineMediumImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionView"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemWithMediumImageAndBg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:leadingIconSize="medium"
        app:leadingIconBackground="circular"
        app:leadingIcon="@drawable/ic_dax_icon"
        app:primaryText="Item with Medium Leading Image " />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeOneLineMediumImageBg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionView"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemWithLargeImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:leadingIconSize="large"
        app:leadingIcon="@drawable/ic_dax_icon"
        app:primaryText="Item with Large Leading Image " />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeOneLineLargeImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionView"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemWithLargeImageAndBG"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:leadingIconSize="large"
        app:leadingIconBackground="circular"
        app:leadingIcon="@drawable/ic_dax_icon"
        app:primaryText="Item with Large Leading Image " />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeOneLineLargeImageBg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionNoCompose"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemWithExtraLargeImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:leadingIconSize="extra_large"
        app:leadingIcon="@drawable/ic_dax_icon"
        app:primaryText="Item with Extra Large Leading Image " />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionNoCompose"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemWithExtraLargeImageAndBG"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:leadingIconSize="extra_large"
        app:leadingIconBackground="circular"
        app:leadingIcon="@drawable/ic_dax_icon"
        app:primaryText="Item with Extra Large Leading Image and Circular Background (icon fills container, so background is not visible) " />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionView"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemWithTrailingIcon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:primaryText="Item With Trailing Icon"
        app:trailingIcon="@drawable/ic_menu_vertical_24" />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeOneLineTrailingIcon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionView"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemWithTrailingIconTinted"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:primaryText="Item With Trailing Icon Tinted"
        app:trailingIconTint="?attr/daxColorSecondaryIcon"
        app:trailingIcon="@drawable/ic_open_in_16" />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeOneLineTrailingTinted"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionView"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemWithLeadingAndTrailingIcons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:leadingIcon="@drawable/ic_globe_16"
        app:leadingIconBackground="circular"
        app:primaryText="Item With Leading and Trailing Icons"
        app:trailingIcon="@drawable/ic_menu_vertical_24" />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeOneLineLeadingTrailing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionView"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemSwitch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:primaryText="Item with Switch Item"
        app:showSwitch="true" />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeOneLineSwitch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionNoCompose"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListSwitchItemWithLeadingIcon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:leadingIcon="@drawable/ic_globe_16"
        app:leadingIconBackground="rounded"
        app:primaryText="Item With Switch and Leading Icon"
        app:showSwitch="true" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionNoCompose"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemSmallImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:leadingIconSize="small"
        app:primaryText="Item disabled" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionView"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemDisabled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:primaryText="Item disabled" />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeOneLineDisabled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionView"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemCustomTextColor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:primaryText="Item with custom text color"
        app:primaryTextColorOverlay="@color/destructive_text_color_selector" />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeOneLineDestructive"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionView"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemWithLongText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:primaryText="Item with long primary text that expands to more lines as primaryTextTruncated is disabled by default"/>

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeOneLineLongText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionView"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemWithLongTextTruncated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:primaryTextTruncated="true"/>

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeOneLineLongTextTruncated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:text="@string/dsShowcaseCaptionView"
        app:typography="caption" />

    <com.duckduckgo.common.ui.view.listitem.OneLineListItem
        android:id="@+id/oneLineListItemWithNewPill"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:primaryText="Item with New Pill"
        app:pillIcon="true"
        app:pillText="New"/>

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeOneLineNewPill"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeOneLineExtras"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>

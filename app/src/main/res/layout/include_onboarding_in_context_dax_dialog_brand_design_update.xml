<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/contextualBrandDesignCtaContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:alpha="0"
    android:background="?attr/onboardingSurfaceBackdrop"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingTop="@dimen/keyline_4"
    android:paddingBottom="@dimen/onboardingContextualBackgroundOverlap"
    android:theme="@style/ThemeOverlay.DuckDuckGo.Onboarding"
    tools:alpha="1">

    <ImageView
        android:id="@+id/contextualBrandDesignBackground"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/onboardingContextualBackgroundOverlapNegative"
        android:adjustViewBounds="true"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_max="@dimen/getDesktopBrowserMaxItemWidth"
        tools:ignore="ContentDescription"
        tools:src="@drawable/bg_onboarding_serp"
        tools:visibility="visible" />

    <com.duckduckgo.common.ui.view.shape.DaxOnboardingBubbleBrandDesignUpdateCardView
        android:id="@+id/contextualBrandDesignCardView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/keyline_4"
        android:layout_marginBottom="32dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="@dimen/getDesktopBrowserMaxItemWidth"
        app:showArrow="false">

        <com.duckduckgo.app.onboarding.ui.view.TouchInterceptingLinearLayout
            android:id="@+id/contextualBrandDesignCardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/keyline_6"
            android:paddingBottom="20dp">

            <FrameLayout
                android:id="@+id/contextualBrandDesignTitleSlot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/keyline_6"
                android:layout_marginBottom="@dimen/keyline_4">

                <com.duckduckgo.common.ui.view.text.DaxTextView
                    android:id="@+id/contextualBrandDesignHiddenTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Typography.DuckDuckGo.Onboarding.Title.InContext"
                    android:visibility="invisible"
                    app:typography="h2"
                    tools:text="@string/onboardingEndDaxDialogTitle"
                    tools:visibility="visible" />

                <com.duckduckgo.app.onboarding.ui.view.DaxTypeAnimationTextView
                    android:id="@+id/contextualBrandDesignTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:textAppearance="@style/Typography.DuckDuckGo.Onboarding.Title.InContext"
                    app:typography="h2" />

            </FrameLayout>

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/contextualBrandDesignDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/keyline_6"
                android:alpha="0"
                android:textAppearance="@style/Typography.DuckDuckGo.Onboarding.Body.InContext"
                tools:alpha="1"
                tools:text="@string/onboardingEndDaxDialogDescription" />

            <!-- Content include slots — only one visible at a time. Unique IDs across both includes. -->
            <include
                android:id="@+id/contextualBrandDesignPrimaryCtaContent"
                layout="@layout/include_brand_design_contextual_dialog_primary_cta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                tools:visibility="visible" />

            <include
                android:id="@+id/contextualBrandDesignOptionsContent"
                layout="@layout/include_brand_design_contextual_dialog_options"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                tools:visibility="gone" />

        </com.duckduckgo.app.onboarding.ui.view.TouchInterceptingLinearLayout>

    </com.duckduckgo.common.ui.view.shape.DaxOnboardingBubbleBrandDesignUpdateCardView>

    <!-- Dismiss button: bordered circular button overlapping card corner. -->
    <ImageView
        android:id="@+id/contextualBrandDesignDismissButton"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="-4dp"
        android:layout_marginEnd="-4dp"
        android:alpha="0"
        android:background="@drawable/bg_brand_design_dismiss_button"
        android:contentDescription="@string/closeContentDescription"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:outlineProvider="none"
        android:padding="8dp"
        android:theme="@style/ThemeOverlay.DuckDuckGo.Onboarding"
        app:tint="?attr/onboardingIconsPrimary"
        android:translationZ="8dp"
        app:layout_constraintEnd_toEndOf="@id/contextualBrandDesignCardView"
        app:layout_constraintTop_toTopOf="@id/contextualBrandDesignCardView"
        app:srcCompat="@drawable/ic_close_16"
        tools:alpha="1" />

</androidx.constraintlayout.widget.ConstraintLayout>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:id="@+id/quickSetupSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="@string/preOnboardingReinstallQuickSetupSubtitle"
        app:typography="body1" />

    <!-- Address bar position row -->
    <LinearLayout
        android:id="@+id/addressBarPositionRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center_vertical"
        android:minHeight="48dp"
        android:orientation="horizontal">

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/preOnboardingReinstallAddressBarLabel"
            app:typography="body1" />

        <RadioGroup
            android:id="@+id/addressBarRadioGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.duckduckgo.common.ui.view.button.RadioButton
                android:id="@+id/addressBarTopRadio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/preOnboardingReinstallAddressBarTop" />

            <com.duckduckgo.common.ui.view.button.RadioButton
                android:id="@+id/addressBarBottomRadio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/preOnboardingReinstallAddressBarBottom" />

        </RadioGroup>

    </LinearLayout>

    <!-- Duck.ai option row -->
    <LinearLayout
        android:id="@+id/duckAiOptionRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:minHeight="48dp"
        android:orientation="horizontal">

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/preOnboardingReinstallDuckAiLabel"
            app:typography="body1" />

        <RadioGroup
            android:id="@+id/duckAiRadioGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.duckduckgo.common.ui.view.button.RadioButton
                android:id="@+id/duckAiOnRadio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/preOnboardingReinstallDuckAiOn" />

            <com.duckduckgo.common.ui.view.button.RadioButton
                android:id="@+id/duckAiOffRadio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/preOnboardingReinstallDuckAiOff" />

        </RadioGroup>

    </LinearLayout>

    <!-- Add widget row -->
    <LinearLayout
        android:id="@+id/addWidgetRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:minHeight="48dp"
        android:orientation="horizontal">

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/preOnboardingReinstallAddWidgetLabel"
            app:typography="body1" />

        <com.duckduckgo.common.ui.view.button.DaxButtonGhost
            android:id="@+id/addWidgetButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/preOnboardingReinstallAddWidgetButton"
            app:buttonSize="standard"
            tools:ignore="DeprecatedWidgetInXml,InvalidDaxButtonProperty" />

    </LinearLayout>

    <!-- Sync passwords row -->
    <LinearLayout
        android:id="@+id/syncPasswordsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:minHeight="48dp"
        android:orientation="horizontal">

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/preOnboardingReinstallSyncLabel"
            app:typography="body1" />

        <com.duckduckgo.common.ui.view.button.DaxButtonGhost
            android:id="@+id/syncButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/preOnboardingReinstallSyncButton"
            app:buttonSize="standard"
            tools:ignore="DeprecatedWidgetInXml,InvalidDaxButtonProperty" />

    </LinearLayout>

    <!-- Set default browser row -->
    <LinearLayout
        android:id="@+id/defaultBrowserRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:minHeight="48dp"
        android:orientation="horizontal">

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/preOnboardingReinstallDefaultBrowserLabel"
            app:typography="body1" />

        <com.duckduckgo.common.ui.view.button.DaxButtonGhost
            android:id="@+id/setDefaultBrowserButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/preOnboardingReinstallDefaultBrowserButton"
            app:buttonSize="standard"
            tools:ignore="DeprecatedWidgetInXml,InvalidDaxButtonProperty" />

    </LinearLayout>

</LinearLayout>
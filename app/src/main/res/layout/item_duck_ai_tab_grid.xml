<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/keyline_2"
    style="@style/Widget.DuckDuckGo.TabCardView"
    app:cardCornerRadius="@dimen/mediumShapeCornerRadius">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardContentsContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/keyline_1">

        <!-- Duck.ai flame icon (top-left) — static drawable, no FaviconManager -->
        <ImageView
            android:id="@+id/favicon"
            android:layout_width="@dimen/listItemImageSmallSize"
            android:layout_height="@dimen/listItemImageSmallSize"
            android:src="@drawable/ic_duck_ai_color_24"
            android:contentDescription="@string/duck_ai_tab_icon_content_description"
            android:layout_marginStart="@dimen/keyline_2"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Unread indicator -->
        <ImageView
            android:id="@+id/tabUnread"
            android:layout_width="9dp"
            android:layout_height="9dp"
            android:importantForAccessibility="no"
            android:src="@drawable/tab_unread_indicator"
            app:layout_constraintCircle="@id/favicon"
            app:layout_constraintCircleAngle="135"
            app:layout_constraintCircleRadius="8dp"
            tools:ignore="MissingConstraints" />

        <!-- Close button (top-right) -->
        <ImageView
            android:id="@+id/close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/closeContentDescription"
            android:layout_marginTop="2dp"
            android:padding="8dp"
            android:src="@drawable/ic_close_16"
            android:background="@drawable/selectable_circular_ripple"
            app:tint="?attr/daxColorTabHighlight"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Selection indicator (runtime-controlled via show()/hide()) -->
        <ImageView
            android:id="@+id/selectionIndicator"
            android:contentDescription="@string/tabNotSelectedIndicator"
            android:layout_marginEnd="@dimen/keyline_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_shape_circle_24"
            app:layout_constraintBottom_toBottomOf="@id/favicon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/favicon" />

        <!-- "Duck.ai" label next to icon -->
        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:id="@+id/duckAiLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/duck_ai_tab_label"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="6dp"
            app:typography="h5"
            app:layout_constrainedWidth="true"
            app:layout_constraintStart_toEndOf="@id/favicon"
            app:layout_constraintEnd_toStartOf="@id/selectionIndicator"
            app:layout_constraintTop_toTopOf="@id/favicon"
            app:layout_constraintBottom_toBottomOf="@id/favicon"
            app:layout_constraintHorizontal_bias="0.0"
            tools:text="Duck.ai" />

        <!-- AI conversation title (entity.title) — large, below header row -->
        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/keyline_2"
            android:layout_marginEnd="6dp"
            android:layout_marginTop="8dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:textIsSelectable="false"
            app:typography="h4"
            app:layout_constrainedWidth="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/favicon"
            tools:text="Explain quantum entanglement" />

        <!-- Screenshot preview -->
        <ImageView
            android:id="@+id/tabPreview"
            android:layout_width="match_parent"
            android:layout_height="@dimen/gridItemPreviewHeight"
            android:layout_marginTop="14dp"
            android:importantForAccessibility="no"
            android:scaleType="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>

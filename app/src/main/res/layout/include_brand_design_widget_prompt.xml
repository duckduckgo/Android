<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/keyline_3">

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:id="@+id/widgetPromptTitleHidden"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/preOnboardingWidgetPromptTitle"
            android:visibility="invisible"
            app:typography="onboarding_title" />

        <com.duckduckgo.common.ui.view.TypeAnimationTextView
            android:id="@+id/widgetPromptTitle"
            style="@style/Typography.DuckDuckGo.Onboarding.Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:includeFontPadding="false"
            android:textColor="?attr/daxColorPrimaryText" />

    </FrameLayout>

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:id="@+id/widgetPromptBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:alpha="0"
        android:gravity="center"
        android:includeFontPadding="false"
        android:paddingHorizontal="@dimen/keyline_3"
        android:text="@string/preOnboardingWidgetPromptBody"
        app:typography="onboarding_body"
        tools:alpha="1" />

    <FrameLayout
        android:id="@+id/widgetPromptMedia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/keyline_6"
        android:alpha="0"
        android:background="@drawable/onboarding_widget_prompt_sketch_frame"
        android:gravity="center"
        tools:alpha="1">

        <ImageView
            android:id="@+id/widgetPromptMediaImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="@dimen/keyline_0"
            android:importantForAccessibility="no"
            android:maxWidth="@dimen/preOnboardingWidgetPromptMediaMaxWidth"
            android:maxHeight="@dimen/preOnboardingWidgetPromptMediaHeight"
            android:scaleType="fitXY"
            android:src="@drawable/onboarding_widget_prompt_preview" />

    </FrameLayout>

</LinearLayout>

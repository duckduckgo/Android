<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="androidx.constraintlayout.widget.ConstraintLayout">

    <ImageView
        android:id="@+id/quickSetupEditRowIcon"
        android:layout_width="@dimen/listItemImageMediumSize"
        android:layout_height="@dimen/listItemImageMediumSize"
        android:layout_marginStart="@dimen/keyline_5"
        android:importantForAccessibility="no"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:id="@+id/quickSetupEditRowPrimaryText"
        style="@style/Typography.DuckDuckGo.Onboarding.ChartComparison"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/keyline_4"
        android:layout_marginEnd="@dimen/keyline_5"
        app:layout_constraintBottom_toTopOf="@id/quickSetupEditRowSecondaryText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/quickSetupEditRowIcon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        tools:text="Primary text" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:id="@+id/quickSetupEditRowSecondaryText"
        style="@style/Typography.DuckDuckGo.Onboarding.Label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="?attr/onboardingAccentTextAlt"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/quickSetupEditRowPrimaryText"
        app:layout_constraintStart_toStartOf="@id/quickSetupEditRowPrimaryText"
        app:layout_constraintTop_toBottomOf="@id/quickSetupEditRowPrimaryText"
        tools:text="Secondary text" />

</merge>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/keyline_4">

    <FrameLayout
        android:id="@+id/quickSetupTitleContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/keyline_6"
        android:layout_marginEnd="@dimen/keyline_6"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:id="@+id/quickSetupTitleHidden"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:includeFontPadding="false"
            android:visibility="invisible"
            app:typography="onboarding_title"
            tools:text="@string/preOnboardingReinstallQuickSetupTitle" />

        <com.duckduckgo.common.ui.view.TypeAnimationTextView
            android:id="@+id/quickSetupTitle"
            style="@style/Typography.DuckDuckGo.Onboarding.Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:includeFontPadding="false"
            android:textColor="?attr/daxColorPrimaryText"
            tools:text="@string/preOnboardingReinstallQuickSetupTitle" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/quickSetupOptionsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/keyline_5"
        android:alpha="0"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/quickSetupTitleContainer">

        <com.duckduckgo.common.ui.view.listitem.OneLineListItem
            android:id="@+id/setDefaultBrowserItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:leadingIcon="@drawable/ic_default_browser_mobile_color_24"
            app:primaryText="@string/preOnboardingReinstallSetDefaultLabel"
            app:showSwitch="true" />

        <com.duckduckgo.common.ui.view.listitem.OneLineListItem
            android:id="@+id/addWidgetItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:leadingIcon="@drawable/ic_add_widget_color_24"
            app:primaryText="@string/preOnboardingReinstallAddHomeScreenWidgetLabel"
            app:showSwitch="true" />

        <LinearLayout
            android:id="@+id/addressBarPositionContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.duckduckgo.common.ui.view.listitem.TwoLineListItem
                android:id="@+id/addressBarPositionItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="false"
                app:leadingIcon="@drawable/ic_address_bar_bottom_color_24"
                app:primaryText="@string/preOnboardingReinstallAddressBarLabel"
                app:secondaryText="@string/preOnboardingReinstallAddressBarTop"
                tools:secondaryText="Top" />

            <com.duckduckgo.common.ui.view.button.DaxButtonGhost
                android:id="@+id/addressBarPositionEditButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/keyline_2"
                android:text="@string/preOnboardingReinstallEditAction"
                app:buttonSize="standard" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/addressBarSearchOptionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.duckduckgo.common.ui.view.listitem.TwoLineListItem
                android:id="@+id/addressBarSearchOptionsItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="false"
                app:leadingIcon="@drawable/ic_ai_chat_color_24"
                app:primaryText="@string/preOnboardingReinstallAddressBarSearchOptionsLabel"
                app:secondaryText="@string/preOnboardingReinstallAddressBarSearchOptionsValue"
                tools:secondaryText="Search and Duck.ai" />

            <com.duckduckgo.common.ui.view.button.DaxButtonGhost
                android:id="@+id/addressBarSearchOptionsEditButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/keyline_2"
                android:text="@string/preOnboardingReinstallEditAction"
                app:buttonSize="standard" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

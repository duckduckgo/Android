<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_top_corners_onboarding_bottom_sheet_drawable"
    android:clipToOutline="true"
    android:theme="@style/ThemeOverlay.DuckDuckGo.Onboarding">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/keyline_5">

        <ImageView
            android:id="@+id/quickSetupAddressBarPositionCloseButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="@dimen/keyline_2"
            android:layout_marginEnd="@dimen/keyline_2"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/closeContentDescription"
            android:padding="@dimen/keyline_2"
            app:srcCompat="@drawable/ic_close_24" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/keyline_6">

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/quickSetupAddressBarPositionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="@string/quickSetupAddressBarPositionTitle"
                android:textColor="?attr/daxColorPrimaryText"
                app:typography="onboarding_title" />

            <com.duckduckgo.app.onboardingquicksetup.ui.BrandDesignAddressBarPositionPicker
                android:id="@+id/addressBarPicker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/keyline_4"
                android:layout_marginBottom="@dimen/keyline_2"
                app:itemSpacingMaxWidth="32dp" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/quickSetupAddressBarPositionCaption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/keyline_3"
                android:fontFamily="@font/ducksansproduct_regular"
                app:textType="secondary"
                app:typography="body1"
                tools:text="@string/quickSetupAddressBarPositionCaption" />

            <com.duckduckgo.common.ui.view.button.DaxButtonPrimary
                android:id="@+id/quickSetupAddressBarPositionDoneButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/keyline_4"
                android:paddingHorizontal="@dimen/keyline_5"
                android:text="@string/quickSetupBottomSheetDone"
                android:textAppearance="@style/Typography.DuckDuckGo.Onboarding.Button"
                tools:ignore="InvalidDaxButtonProperty" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>

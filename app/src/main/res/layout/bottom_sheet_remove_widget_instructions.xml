<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_top_corners_onboarding_bottom_sheet_drawable"
    android:theme="@style/ThemeOverlay.DuckDuckGo.Onboarding">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/keyline_5">

        <ImageView
            android:id="@+id/removeWidgetInstructionsCloseButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="@dimen/keyline_2"
            android:layout_marginEnd="@dimen/keyline_2"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/closeContentDescription"
            android:padding="@dimen/keyline_2"
            app:srcCompat="@drawable/ic_close_24" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/quickSetupBottomSheetHorizontalPadding">

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:id="@+id/removeWidgetInstructionsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingHorizontal="@dimen/keyline_3"
                android:text="@string/quickSetupRemoveHomeScreenWidgetTitle"
                android:textColor="?attr/daxColorPrimaryText"
                app:typography="onboarding_title" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/keyline_6"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.duckduckgo.common.ui.view.text.DaxTextView
                    android:layout_width="@dimen/quickSetupRemoveWidgetStepNumberSize"
                    android:layout_height="@dimen/quickSetupRemoveWidgetStepNumberSize"
                    android:background="@drawable/background_remove_widget_step_number"
                    android:fontFamily="@font/ducksansproduct_bold"
                    android:gravity="center"
                    android:text="@string/quickSetupRemoveHomeScreenWidgetStep1Number"
                    android:textColor="?attr/onboardingAccentTextPrimary"
                    android:textSize="18sp" />

                <com.duckduckgo.common.ui.view.text.DaxTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/keyline_3"
                    android:gravity="center_vertical"
                    android:text="@string/quickSetupRemoveHomeScreenWidgetStep1"
                    android:textAppearance="@style/Typography.DuckDuckGo.Onboarding.Body"
                    android:textSize="18sp"
                    app:textType="secondary"
                    app:typography="body1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.duckduckgo.common.ui.view.text.DaxTextView
                    android:layout_width="@dimen/quickSetupRemoveWidgetStepNumberSize"
                    android:layout_height="@dimen/quickSetupRemoveWidgetStepNumberSize"
                    android:background="@drawable/background_remove_widget_step_number"
                    android:fontFamily="@font/ducksansproduct_bold"
                    android:gravity="center"
                    android:text="@string/quickSetupRemoveHomeScreenWidgetStep2Number"
                    android:textColor="?attr/onboardingAccentTextPrimary"
                    android:textSize="18sp" />

                <com.duckduckgo.common.ui.view.text.DaxTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/keyline_3"
                    android:gravity="center_vertical"
                    android:text="@string/quickSetupRemoveHomeScreenWidgetStep2"
                    android:textAppearance="@style/Typography.DuckDuckGo.Onboarding.Body"
                    app:textType="secondary"
                    app:typography="body1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.duckduckgo.common.ui.view.text.DaxTextView
                    android:layout_width="@dimen/quickSetupRemoveWidgetStepNumberSize"
                    android:layout_height="@dimen/quickSetupRemoveWidgetStepNumberSize"
                    android:background="@drawable/background_remove_widget_step_number"
                    android:fontFamily="@font/ducksansproduct_bold"
                    android:gravity="center"
                    android:text="@string/quickSetupRemoveHomeScreenWidgetStep3Number"
                    android:textColor="?attr/onboardingAccentTextPrimary"
                    android:textSize="18sp" />

                <com.duckduckgo.common.ui.view.text.DaxTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/keyline_3"
                    android:gravity="center_vertical"
                    android:text="@string/quickSetupRemoveHomeScreenWidgetStep3"
                    android:textAppearance="@style/Typography.DuckDuckGo.Onboarding.Body"
                    app:textType="secondary"
                    app:typography="body1" />
            </LinearLayout>

            <com.duckduckgo.common.ui.view.button.DaxButtonPrimary xmlns:tools="http://schemas.android.com/tools"
                android:id="@+id/removeWidgetInstructionsDoneButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/keyline_5"
                android:text="@string/quickSetupBottomSheetDone"
                android:textAppearance="@style/Typography.DuckDuckGo.Onboarding.Button"
                tools:ignore="InvalidDaxButtonProperty" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>

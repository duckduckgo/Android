<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingVertical="8dp"
    android:paddingStart="12dp"
    android:paddingEnd="4dp">

    <ImageView
        android:id="@+id/rowIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:importantForAccessibility="no"
        tools:srcCompat="@drawable/ic_shield_color_24_rebrand" />

    <com.duckduckgo.common.ui.view.text.DaxTextView
        android:id="@+id/rowText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:textAppearance="@style/Typography.DuckDuckGo.Onboarding.ChartComparison"
        tools:text="Row text placeholder" />

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:importantForAccessibility="no"
        android:padding="8dp"
        app:srcCompat="@drawable/ic_cross_recolorable_gray60_24" />

    <com.duckduckgo.common.ui.view.divider.VerticalDivider
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginStart="3dp"
        android:layout_marginEnd="4dp" />

    <ImageView
        android:id="@+id/rowCheck"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:alpha="0"
        android:importantForAccessibility="no"
        android:padding="8dp"
        android:scaleX="0"
        android:scaleY="0"
        app:srcCompat="@drawable/avd_check_green_24"
        tools:alpha="1"
        tools:scaleX="1"
        tools:scaleY="1" />

</LinearLayout>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Title: FrameLayout with hidden DaxTextView for measurement + TypeAnimationTextView for typing -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:paddingHorizontal="12dp">

        <com.duckduckgo.common.ui.view.text.DaxTextView
            android:id="@+id/comparisonChartTitleHidden"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:visibility="invisible"
            android:text="@string/preOnboardingDaxDialog2Title"
            app:typography="onboarding_title" />

        <com.duckduckgo.common.ui.view.TypeAnimationTextView
            android:id="@+id/comparisonChartTitle"
            style="@style/Typography.DuckDuckGo.Onboarding.Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:textColor="?attr/daxColorPrimaryText" />

    </FrameLayout>

    <!-- Comparison Table -->
    <LinearLayout
        android:id="@+id/comparisonTable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:alpha="0"
        android:orientation="vertical"
        tools:alpha="1">

        <!-- Header Row: Chrome + DDG logos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end|center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="4dp"
            android:paddingBottom="16dp">

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/ic_chrome_comparison_chart" />

            <View
                android:layout_width="8dp"
                android:layout_height="0dp" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/ic_ddg_comparison_chart" />

        </LinearLayout>

        <!-- Row 1: Search privately by default (highlighted) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/background_comparison_chart_row_highlighted"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/temp_ic_onboarding_globe" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/preOnboardingComparisonChartItem1"
                app:typography="onboarding_body" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:importantForAccessibility="no"
                android:padding="8dp"
                app:srcCompat="@drawable/ic_cross_recolorable_gray60_24" />

            <com.duckduckgo.common.ui.view.divider.VerticalDivider
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="4dp" />

            <ImageView
                android:id="@+id/check1"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:alpha="0"
                android:importantForAccessibility="no"
                android:padding="8dp"
                android:scaleX="0"
                android:scaleY="0"
                app:srcCompat="@drawable/ic_check_green_24"
                tools:alpha="1"
                tools:scaleX="1"
                tools:scaleY="1" />

        </LinearLayout>

        <!-- Row 2: Block 3rd-party trackers (transparent) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/temp_ic_onboarding_shield" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/preOnboardingComparisonChartItem2"
                app:typography="onboarding_body" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:importantForAccessibility="no"
                android:padding="8dp"
                app:srcCompat="@drawable/ic_cross_recolorable_gray60_24" />

            <com.duckduckgo.common.ui.view.divider.VerticalDivider
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="4dp" />

            <ImageView
                android:id="@+id/check2"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:alpha="0"
                android:importantForAccessibility="no"
                android:padding="8dp"
                android:scaleX="0"
                android:scaleY="0"
                app:srcCompat="@drawable/ic_check_green_24"
                tools:alpha="1"
                tools:scaleX="1"
                tools:scaleY="1" />

        </LinearLayout>

        <!-- Row 3: Block cookie requests & pop-ups (highlighted) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/background_comparison_chart_row_highlighted"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/temp_ic_onboarding_cookie" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/preOnboardingBrandDesignComparisonChartItem3"
                app:typography="onboarding_body" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:importantForAccessibility="no"
                android:padding="8dp"
                app:srcCompat="@drawable/ic_cross_recolorable_gray60_24" />

            <com.duckduckgo.common.ui.view.divider.VerticalDivider
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="4dp" />

            <ImageView
                android:id="@+id/check3"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:alpha="0"
                android:importantForAccessibility="no"
                android:padding="8dp"
                android:scaleX="0"
                android:scaleY="0"
                app:srcCompat="@drawable/ic_check_green_24"
                tools:alpha="1"
                tools:scaleX="1"
                tools:scaleY="1" />

        </LinearLayout>

        <!-- Row 4: Block targeted ads (transparent) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/temp_ic_onboarding_profile_blocker" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/preOnboardingComparisonChartItem4"
                app:typography="onboarding_body" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:importantForAccessibility="no"
                android:padding="8dp"
                app:srcCompat="@drawable/ic_cross_recolorable_gray60_24" />

            <com.duckduckgo.common.ui.view.divider.VerticalDivider
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="4dp" />

            <ImageView
                android:id="@+id/check4"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:alpha="0"
                android:importantForAccessibility="no"
                android:padding="8dp"
                android:scaleX="0"
                android:scaleY="0"
                app:srcCompat="@drawable/ic_check_green_24"
                tools:alpha="1"
                tools:scaleX="1"
                tools:scaleY="1" />

        </LinearLayout>

        <!-- Row 5: Erase browsing data swiftly (highlighted) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/background_comparison_chart_row_highlighted"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/temp_ic_onboarding_fire" />

            <com.duckduckgo.common.ui.view.text.DaxTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/preOnboardingBrandDesignComparisonChartItem5"
                app:typography="onboarding_body" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:importantForAccessibility="no"
                android:padding="8dp"
                app:srcCompat="@drawable/ic_cross_recolorable_gray60_24" />

            <com.duckduckgo.common.ui.view.divider.VerticalDivider
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="4dp" />

            <ImageView
                android:id="@+id/check5"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:alpha="0"
                android:importantForAccessibility="no"
                android:padding="8dp"
                android:scaleX="0"
                android:scaleY="0"
                app:srcCompat="@drawable/ic_check_green_24"
                tools:alpha="1"
                tools:scaleX="1"
                tools:scaleY="1" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>

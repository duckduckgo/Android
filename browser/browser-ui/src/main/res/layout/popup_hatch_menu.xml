<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/popup_menu_bg"
    android:orientation="vertical">

    <com.duckduckgo.common.ui.view.PopupMenuItemView
        android:id="@+id/hatchMenuReturnToTab"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:leadingIcon="@drawable/ic_go_back_circle_recolorable_16"
        app:primaryText="@string/hatchMenuReturnTab" />

    <com.duckduckgo.common.ui.view.PopupMenuItemView
        android:id="@+id/hatchMenuCloseTab"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:primaryText="@string/hatchMenuCloseTab"
        app:leadingIcon="@drawable/ic_close_24"
        app:leadingIconTint="?daxColorDestructive"
        app:primaryTextType="destructive" />

    <com.duckduckgo.common.ui.view.PopupMenuItemView
        android:id="@+id/hatchMenuBurnTab"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:primaryText="@string/hatchMenuBurnTab"
        app:leadingIcon="@drawable/ic_fire_24"
        app:leadingIconTint="?daxColorDestructive"
        app:primaryTextType="destructive" />

</LinearLayout>
